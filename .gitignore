# ===================================
# Spending Manager — monorepo .gitignore
# ===================================

# --- CRITICAL: real bank statements & secrets (first commit!) ---
*.pdf
*.xlsx
*.xls
*.csv
.env
.env.*
application-local.properties
application-*-local.properties

# ===================================
# Java / Spring Boot (backend/)
# ===================================
backend/target/
*.class
*.jar
*.war

# Maven
.mvn/wrapper/maven-wrapper.jar
backend/.flattened-pom.xml

# ===================================
# Node / React / Vite (frontend/)
# ===================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/coverage/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ===================================
# IDE
# ===================================
# IntelliJ IDEA
.idea/
*.iml
*.ipr
*.iws
out/

# VS Code (keep settings shared? remove the ! lines if not)
.vscode/*
!.vscode/extensions.json

# ===================================
# OS
# ===================================
.DS_Store
Thumbs.db
desktop.ini

# ===================================
# Docker / runtime
# ===================================
postgres-data/
*.pid